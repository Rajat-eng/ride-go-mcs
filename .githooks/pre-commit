#!/usr/bin/env bash

set -euo pipefail

staged_go_files="$(git diff --cached --name-only --diff-filter=ACMR -- '*.go')"

if [ -z "$staged_go_files" ]; then
  exit 0
fi

echo "pre-commit: formatting staged Go files with gofmt..."

# gofmt prints parse errors with file:line:column if syntax is invalid.
printf '%s\n' "$staged_go_files" | xargs gofmt -w

# Re-stage because gofmt may rewrite files.
printf '%s\n' "$staged_go_files" | xargs git add

# Defensive check in case any file still differs from gofmt output.
unformatted="$(printf '%s\n' "$staged_go_files" | xargs gofmt -l)"
if [ -n "$unformatted" ]; then
  echo "pre-commit: gofmt still reports formatting issues:"
  echo "$unformatted"
  exit 1
fi

echo "pre-commit: gofmt check passed."
